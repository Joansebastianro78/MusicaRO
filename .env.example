# Jamendo (https://developer.jamendo.com/v3.0/docs)
# Client ID gratuito, se obtiene registrando una app en:
# https://devportal.jamendo.com
# Se usa SOLO server-side, dentro de api/_lib/jamendo.ts — nunca lo
# expongas con el prefijo VITE_ ni lo metas en el bundle del cliente.
# Si lo dejas vacío, /api/playlist simplemente omite Jamendo y sirve
# solo tracks de Audius (que no requiere ninguna credencial).
JAMENDO_CLIENT_ID=

# Audius (https://docs.audius.co/api) — opcional.
# La API pública de Audius NO requiere credenciales para buscar/reproducir.
# Esta API Key es solo para subir tus límites de rate limit; podés
# generarla gratis en https://audius.co/settings (Developer Apps).
AUDIUS_API_KEY=

# En Vercel: Project Settings → Environment Variables, añade estas
# claves (Production, Preview y Development). En local, copia este
# archivo a ".env" (vercel dev lo carga automáticamente).
