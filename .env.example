# Credenciales de la API de HookSounds (https://docs.hooksounds.com/guides/auth/)
# Se usan SOLO server-side, dentro de api/_lib/hooksounds.ts — nunca las
# expongas con el prefijo VITE_ ni las metas en el bundle del cliente.
HOOKSOUNDS_API_KEY=
HOOKSOUNDS_API_TOKEN=

# En Vercel: Project Settings → Environment Variables, añade estas dos
# claves (Production, Preview y Development). En local, copia este
# archivo a ".env" (vercel dev lo carga automáticamente).
